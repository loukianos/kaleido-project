PORT=8080
ETH_RPC_URL=http://127.0.0.1:31545
API_ETH_RPC_URL=http://host.docker.internal:31545
CHAIN_ID=1337
DATABASE_URL=postgres://loan_notes:loan_notes@127.0.0.1:5432/loan_notes?sslmode=disable
LOAN_BASE_URI=http://localhost:8080/loans/
# Local-only values. Fill these in .env; do not commit real keys.
DEPLOYER_PRIVATE_KEY=
KEY_ENCRYPTION_MASTER_KEY=

# OIDC (Keycloak from docker-compose; tokens carry the host-published issuer)
OIDC_ISSUER_URL=http://localhost:8081/realms/loan-notes
API_OIDC_JWKS_URL=http://keycloak:8080/realms/loan-notes/protocol/openid-connect/certs
OIDC_AUDIENCE=loan-notes-api

# Extra platform signing keys for concurrent servicer chain writes
SERVICER_KEY_POOL_SIZE=2

# Demo values
API_URL=http://localhost:8080
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_ADMIN_PASSWORD=
SERVICER_CLIENT_SECRET=
ALICE_PASSWORD=
BOB_PASSWORD=
